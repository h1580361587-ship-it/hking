函数save(){
localStorage.setItem('成就_系统'，JSON.stringify(成就))；
        }

        // 添加成就
函数addAchievement(名称、描述、速率){
如果(！name||！name.trim()){showToast('请输入成就名称！'，false)；返回false；}
if(成就.some(a=>a.name===name.trim())){
showToast('这个成就已经存在啦！'，false)；
返回false；
            }
成就.推({
name:name.trim()，
说明：(desc||").Trim()||'暂无描述'，
速率：Math.min(100，Math.max(0，parseInt(速率)||0))，
已完成：false，
doneTime：空，
addTime:getNowStr()，
            });
节省()；
提供()；
showtoast('✅成就"${name.trim()}”已添加！‘）；
返回true；
        }

        // 切换完成
函数toggleAchieve(index){
Const项目=成就[指标]；
if(项){
item.completed=！item.completed；
item.doneTime=item。是否完成？getNowStr()：空；
节省()；
提供()；
if(item.completed){
showToast('🏆 成就"${item.name}"已解锁！太棒了！‘)；
}else{
showToast('∀已撤回"${item.name}"')；
                }
            }
        }

// 删除
函数deleteAchieve(index){
Const项目=成就[指标]；
if(项目&&确认(‘确定要删除成就"${item.name}"吗？‘)){
成就.拼接(索引，1)；
节省()；
提供()；
showToast(‘已删除"${item.name}"')；
            }
        }

