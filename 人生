            { name: '🎯 自律达人', desc: '连续365天坚持早起（7点前起床）', rate: 4 },
            { name: '✈️ 蓝天之约', desc: '体验一次滑翔伞或跳伞', rate: 3 },
            { name: '🤿 海底探秘', desc: '考取潜水证，探索海底世界', rate: 2 },
            { name: '📝 书写人生', desc: '坚持写日记超过1000天', rate: 1 },
            { name: '🎓 终身学习', desc: '工作后考取一个含金量高的专业证书', rate: 16 },
            { name: '🏆 巅峰时刻', desc: '在某个领域获得省级以上奖项', rate: 5 },
            { name: '🌟 极光之梦', desc: '在北极圈内亲眼看到一次极光', rate: 2 },
            { name: '🎪 热血青春', desc: '去现场看一次偶像的演唱会', rate: 28 },
            { name: '🚴 千里之行', desc: '完成一次超过100公里的长途骑行', rate: 4 },
            { name: '🏕️ 星空露营', desc: '在野外露营一次，看满天繁星', rate: 20 },
            { name: '🎨 妙笔生花', desc: '完成一幅自己满意的绘画或书法作品', rate: 11 },
        ];

//=============================================
        // 📊 数据
//=============================================
        let achievements = JSON.parse(localStorage.getItem('achievement_system')) || [];
        let filterMode = 'all';

//=============================================
        // 🔧 DOM
//=============================================
        const achieveList = document.getElementById('achieveList');
        const emptyState = document.getElementById('emptyState');
        const inputName = document.getElementById('inputName');
        const inputDesc = document.getElementById('inputDesc');
        const inputRate = document.getElementById('inputRate');
        const addCustomBtn = document.getElementById('addCustomBtn');
        const presetGrid = document.getElementById('presetGrid');
        const overallPct = document.getElementById('overallPct');
        const overallBar = document.getElementById('overallBar');
        const doneTotal = document.getElementById('doneTotal');
        const todoTotal = document.getElementById('todoTotal');
        const grandTotal = document.getElementById('grandTotal');
        const rankDisplay = document.getElementById('rankDisplay');
        const listLabel = document.getElementById('listLabel');
        const toast = document.getElementById('toast');

        // =============================================
        // 🛠️ 工具函数
        // =============================================
函数getNowStr(){
const d=新日期()；
返回'${d.getFullYear()}年${d.getMonth()+1}月${d.GETDATE()}日'；
        }

函数escHtml(t){
Const el=document.createElement('span')；
el.textContent=t；
return el.innerHTML；
        }

//吐司提示
设toastTimer=null；
函数showToast(msg，isGood=true){
toast.textContent=msg；
toast.style.background=isGood
？'rgba(76，175，80，0.95)'
：'rgba(255，82，82，0.95)'；
toast.classList.add('show')；
clearTimeout(toastTimer)；
toastTimer=setTimeout(()=>toast.classList.remove('show')，2500)；
        }

// 获取等级
函数getRank(pct){
if(pct>=80)返回'🌟 传说'；
if(pct>=60)return'🏅黄金'；
if(pct>=40)返回‘🥈 白银’；
if(pct>=20)返回'🥉 青铜'；
return'🌱新手'；
        }

//=============================================
// 🎨 渲染
//=============================================
函数render(){
const total=成就.长度；
Const done=resultations.filter(a=>a.completed).length；
Const todo=total-done；
Const pct=total======0？0:Math.round((完成/总计)*100)；

// 统计
overallPct.textContent=pct+"%"；
overallBar.style.width=pct+'%'；
doneTotal.textContent=完成；
todoTotal.textContent=todo；
grandTotal.textContent=total；
rankDisplay.textContent=getRank(pct)；

// 筛选
设filtered=results；
if(FILTERMODE==='done')filtered=resultations。filter(a=>a.完成)；
其他if(FILTERMODE==='todo')筛选=结果。筛选(a=>！一个。完成)；

// 空状态
emptyState.style.display=(total====0)？'Block'：'none'；

// 标题
常量标签={all：'--全部成就--'，完成时间：'--已解锁 ✅ --'，todo：'--未解锁 🔒 --'}；
listLabel.textContent=标签[FILTERMODE]||'--成就--'；

// 渲染列表
accieveList.innerHTML=已筛选。映射((item，idx)=>{
Const realIdx=resultations.indexOf(item)；
常数费率=项目。费率||0；
返回'
<div class="accieve-card${item.completed？'完成'："}"data-index="${realIdx}">
<div class="卡顶">
<div class="奖杯图标">${item.completed？'🏆'：'🏅'}</div>
<div class="卡内容">
<div class="accieve-name">${escHtml(item.name)}</div>
<div class="accieve-condition">📖 ${escHtml(项目。DESC||'暂无描述')}</div>
</div>
</div>
<div class="card-bottom">
<div class="完成率">
<span class="rate-text">🏆 <span class="pct-num">${rate}%</span>的玩家已完成该成就</span>
<div class="rate-bar-wrap">
<div class="rate-fill"style="width：${rate}%；"></div>
</div>
</div>
<div class="card-actions">
<span class="状态标签${item.completed？'Done'：'todo'}">
${item.completed？'✅ 已解锁'：'🔒 未解锁'}
</span>
<button class="mark-btn${item。完成？'undo'：'complete'}"data-index="${realIdx}">
${item.completed？'彷徨撤回'：'✓ 标记完成‘}
</button>
<按钮class="delete-btn"data-index="${realIdx}">✕</button>
</div>
</div>
</div>
`;
}).join(")；
        }

