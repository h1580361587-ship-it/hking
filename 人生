            { name: '🚗 一路顺风', desc: '考取驾照，安全驾驶满一年', rate: 55 },
            { name: '💍 执子之手', desc: '找到人生伴侣，步入婚姻殿堂', rate: 65 },
            { name: '👶 新生命的礼物', desc: '迎接一个新生命来到这个世界', rate: 48 },
            { name: '🌍 环游世界', desc: '去超过10个不同的国家旅行', rate: 8 },
            { name: '🏔️ 登峰造极', desc: '成功登顶一座海拔5000米以上的雪山', rate: 3 },
            { name: '📚 博览群书', desc: '一年内读完50本书并写下心得', rate: 6 },
            { name: '💰 第一桶金', desc: '通过自己的努力攒到第一个10万元', rate: 35 },
            { name: '🏃 挑战极限', desc: '完成一次全程马拉松（42.195公里）', rate: 2 },
            { name: '🎸 多才多艺', desc: '学会一门乐器并能完整弹奏一首曲子', rate: 15 },
            { name: '🌊 乘风破浪', desc: '学会游泳并成功横渡一次河流或湖泊', rate: 12 },
            { name: '🎤 一展歌喉', desc: '在100人以上的场合登台表演一次', rate: 9 },
            { name: '📸 光影大师', desc: '用相机记录下一年四季的美景并办展', rate: 1 },
            { name: '🍳 美食家', desc: '学会做20道拿手好菜，能独立宴请一桌客人', rate: 18 },
